[MASTER]
init-hook='import sys; sys.path.append(".")'
ignore-patterns=test_.*
persistent=no
load-plugins=

[MESSAGES CONTROL]
disable=
    C0114,  # missing-module-docstring
    C0115,  # missing-class-docstring
    C0116,  # missing-function-docstring
    R0801,  # duplicate-code
    W0212,  # protected-access
    R0913,  # too-many-arguments
    R0914,  # too-many-locals
    C0330,  # wrong-hanging-indentation
    C0326,  # bad-whitespace
    R0903,  # too-few-public-methods
    W0142,  # star-args
    W0221,  # arguments-differ
    W0232,  # no-init
    C0413,  # import-outside-toplevel
    R0401,  # cyclic-import

[REPORTS]
output-format=text
reports=no

[FORMAT]
max-line-length=120
indent-string='    '
indent-after-paren=4

[VARIABLES]
init-import=no
dummy-variables-rgx=_$|dummy

[BASIC]
bad-names=foo,bar,baz,toto,tutu,tata

[DESIGN]
max-args=5
max-attributes=7
max-bool-expr=5
max-branches=12
max-locals=15
max-parents=7
max-public-methods=20
max-returns=6
max-statements=50
min-public-methods=2

[CLASSES]
exclude-protected=_asdict,_fields,_make,_replace,_source,_split_fields

[IMPORTS]
known-standard-library=
known-third-party=numpy,scipy,sklearn,pandas,torch,transformers

# ============================================================
# Medical AI Assistant - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Optional: OpenAI API key (for GPT-4 backend)
OPENAI_API_KEY=sk-your-key-here

# Optional: xAI API key (for xAI / Grok backend)
XAI_API_KEY=xai-your-key-here
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4-1-fast-reasoning

# Optional: Groq API key (OpenAI-compatible Groq backend)
GROQ_API_KEY=gsk_your-key-here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=openai/gpt-oss-20b

# Optional: HuggingFace token (for gated models like Llama-3)
HF_TOKEN=hf_your-token-here

# Optional: PhysioNet credentials (for MIMIC dataset downloads)
PHYSIONET_USER=your_username
PHYSIONET_PASS=your_password

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=medical_multimodal_ai

# Logging
LOG_LEVEL=INFO
